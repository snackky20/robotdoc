<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ROBOT DOC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #1a1a1a;
    --border: #2a2a2a;
    --border-bright: #3a3a3a;
    --text: #e8e8e8;
    --text-muted: #666;
    --text-dim: #444;
    --accent: #00ff88;
    --accent-dim: rgba(0,255,136,0.12);
    --accent-glow: rgba(0,255,136,0.3);
    --red: #ff4444;
    --red-dim: rgba(255,68,68,0.12);
    --green: #00ff88;
    --green-dim: rgba(0,255,136,0.12);
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.5;
  }

  /* SCANLINE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* HEADER */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logo {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .logo-sep {
    width: 1px;
    height: 20px;
    background: var(--border-bright);
  }

  .header-sub {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent-glow);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .version-badge {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
    border: 1px solid var(--border-bright);
    padding: 3px 8px;
  }

  /* LAYOUT */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2px;
    min-height: calc(100vh - 52px);
  }

  /* SIDEBAR */
  .sidebar {
    background: var(--surface);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* PANEL */
  .panel {
    border-bottom: 1px solid var(--border);
  }

  .panel-header {
    padding: 10px 16px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .panel-label {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .panel-body {
    padding: 16px;
  }

  /* CS PILLS */
  .cs-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 12px;
    max-height: 200px;
    overflow-y: auto;
  }

  .cs-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 10px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    transition: border-color 0.15s;
  }

  .cs-item:hover { border-color: var(--border-bright); }

  .cs-item.selected {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
  }

  .cs-remove {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    padding: 0 2px;
    transition: color 0.15s;
    font-family: var(--mono);
  }

  .cs-remove:hover { color: var(--red); }

  .cs-add-row {
    display: flex;
    gap: 6px;
  }

  /* INPUTS */
  input[type="text"], textarea, select {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--mono);
    font-size: 12px;
    padding: 8px 10px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    -webkit-appearance: none;
  }

  input[type="text"]:focus,
  textarea:focus,
  select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent-dim);
  }

  input::placeholder, textarea::placeholder {
    color: var(--text-dim);
  }

  /* BUTTONS */
  .btn {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text-muted);
    padding: 8px 14px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn:hover {
    border-color: var(--border-bright);
    color: var(--text);
  }

  .btn-accent {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
  }

  .btn-accent:hover {
    background: #00cc6a;
    border-color: #00cc6a;
    color: #000;
  }

  .btn-ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text-muted);
  }

  .btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .btn:disabled:hover {
    border-color: var(--border);
    color: var(--text-muted);
  }

  /* MAIN CONTENT */
  .main {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: none;
    display: flex;
    flex-direction: column;
  }

  /* INPUT ZONE */
  .input-zone {
    padding: 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .input-row {
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .cs-select-wrapper {
    position: relative;
    flex-shrink: 0;
    width: 160px;
  }

  .cs-select-wrapper::after {
    content: '▾';
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 10px;
    color: var(--text-muted);
    pointer-events: none;
  }

  select {
    padding-right: 28px;
    cursor: pointer;
    height: 36px;
  }

  textarea {
    flex: 1;
    resize: vertical;
    min-height: 160px;
    font-size: 11px;
    line-height: 1.6;
  }

  .action-row {
    display: flex;
    gap: 6px;
  }

  /* RESULTS HEADER */
  .results-header {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface2);
    gap: 12px;
  }

  .results-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .results-count {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .results-count span {
    color: var(--accent);
    font-weight: 700;
  }

  /* TABS */
  .tabs {
    display: flex;
    gap: 2px;
  }

  .tab {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.12s;
  }

  .tab:hover { border-color: var(--border-bright); color: var(--text); }

  .tab.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
  }

  .copy-actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  /* SUMMARY BAR */
  .summary-bar {
    display: flex;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .summary-item {
    flex: 1;
    padding: 12px 16px;
    border-right: 1px solid var(--border);
  }

  .summary-item:last-child { border-right: none; }

  .summary-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .summary-value {
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .val-deposit { color: var(--green); }
  .val-withdraw { color: var(--red); }
  .val-net-pos { color: var(--green); }
  .val-net-neg { color: var(--red); }
  .val-neutral { color: var(--text-muted); }

  /* TABLE */
  .table-wrap {
    flex: 1;
    overflow: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead th {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 10px 16px;
    text-align: left;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    position: sticky;
    top: 0;
  }

  thead th.num { text-align: right; }

  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }

  tbody tr:hover { background: var(--surface2); }

  tbody td {
    padding: 10px 16px;
    font-size: 12px;
    vertical-align: middle;
  }

  td.mono { font-family: var(--mono); }
  td.num { text-align: right; font-family: var(--mono); font-weight: 700; }

  .type-badge {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 3px 8px;
    text-transform: uppercase;
    display: inline-block;
  }

  .type-dep {
    background: var(--green-dim);
    color: var(--green);
    border: 1px solid rgba(0,255,136,0.2);
  }

  .type-wd {
    background: var(--red-dim);
    color: var(--red);
    border: 1px solid rgba(255,68,68,0.2);
  }

  .val-dep { color: var(--green); }
  .val-wd { color: var(--red); }

  .empty-state {
    padding: 60px 20px;
    text-align: center;
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .empty-state .icon {
    font-size: 28px;
    margin-bottom: 12px;
    opacity: 0.3;
  }

  /* TOAST */
  #toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: var(--accent);
    color: #000;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 10px 18px;
    text-transform: uppercase;
    transform: translateY(80px);
    opacity: 0;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 9999;
    pointer-events: none;
  }

  #toast.show {
    transform: translateY(0);
    opacity: 1;
  }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-bright); }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-dim); }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .container {
      grid-template-columns: 1fr;
      padding: 12px;
    }
    .main { border-left: 1px solid var(--border); }
    .results-header { flex-wrap: wrap; gap: 8px; }
    .summary-bar { flex-wrap: wrap; }
    .summary-item { min-width: 50%; }
    .input-row { flex-direction: column; }
    .cs-select-wrapper { width: 100%; }
  }

  /* ENTRY ANIMATION */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  tbody tr {
    animation: fadeIn 0.15s ease forwards;
  }

  .sidebar { animation: fadeIn 0.2s ease forwards; }
  .main { animation: fadeIn 0.25s ease forwards; }
</style>
</head>
<body>

<header>
  <div class="header-left">
    <div class="logo">Robot Doc</div>
    <div class="logo-sep"></div>
    <div class="header-sub">Transaction Parser</div>
  </div>
  <div style="display:flex;align-items:center;gap:12px;">
    <div class="status-dot"></div>
    <div class="version-badge">v2.0</div>
  </div>
</header>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">

    <div class="panel">
      <div class="panel-header">
        <div class="panel-label">CS Management</div>
      </div>
      <div class="panel-body">
        <div class="cs-list" id="csList"></div>
        <div class="cs-add-row">
          <input type="text" id="newCsInput" placeholder="Nama CS..." 
            onkeydown="if(event.key==='Enter')addCs()" style="flex:1">
          <button class="btn btn-accent" onclick="addCs()" style="padding:8px 12px;">+</button>
        </div>
      </div>
    </div>

    <!-- SUMMARY SIDEBAR -->
    <div class="panel" style="flex:1;">
      <div class="panel-header">
        <div class="panel-label">Session Stats</div>
      </div>
      <div class="panel-body" style="display:flex;flex-direction:column;gap:12px;">
        <div>
          <div class="summary-label">Total Transaksi</div>
          <div class="summary-value val-neutral" id="statTotal">—</div>
        </div>
        <div style="height:1px;background:var(--border);"></div>
        <div>
          <div class="summary-label">Total Deposit</div>
          <div class="summary-value val-deposit" id="statDeposit">—</div>
        </div>
        <div>
          <div class="summary-label">Total Withdraw</div>
          <div class="summary-value val-withdraw" id="statWithdraw">—</div>
        </div>
        <div style="height:1px;background:var(--border);"></div>
        <div>
          <div class="summary-label">Net</div>
          <div class="summary-value" id="statNet">—</div>
        </div>
      </div>
    </div>

  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- INPUT ZONE -->
    <div class="input-zone">
      <div class="input-row">
        <div class="cs-select-wrapper">
          <select id="csSelect" onchange="processData()">
            <option value="">— CS —</option>
          </select>
        </div>
        <textarea id="rawData" placeholder="Paste data transaksi di sini..." oninput="processData()"></textarea>
      </div>
      <div class="action-row">
        <button class="btn btn-accent" onclick="processData()">Proses</button>
        <button class="btn btn-ghost" onclick="clearData()">Hapus</button>
      </div>
    </div>

    <!-- RESULTS HEADER -->
    <div class="results-header">
      <div class="results-meta">
        <div class="results-count">HASIL: <span id="successCount">0</span></div>
      </div>
      <div class="tabs">
        <button class="tab active" id="tabAll" onclick="setTab('all')">Semua</button>
        <button class="tab" id="tabDeposit" onclick="setTab('deposit')">Deposit</button>
        <button class="tab" id="tabWithdraw" onclick="setTab('withdraw')">Withdraw</button>
      </div>
      <div class="copy-actions">
        <button class="btn" id="btnCopyNom" onclick="copyAllNominal()" disabled>Copy Nominal</button>
        <button class="btn btn-accent" id="btnCopyAll" onclick="copyAllData()" disabled>Copy Data</button>
      </div>
    </div>

    <!-- TABLE -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>CS</th>
            <th>Nama Rekening</th>
            <th>ID User</th>
            <th>Tipe</th>
            <th class="num">Nominal</th>
          </tr>
        </thead>
        <tbody id="successTableBody">
          <tr>
            <td colspan="5">
              <div class="empty-state">
                <div class="icon">◈</div>
                <div>Menunggu data...</div>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

  </div>
</div>

<div id="toast"></div>

<script>
  /* =====================
     STATE
  ===================== */
  let activeTab = 'all';
  let allResults = [];
  let selectedCS = '';
  let csNames = JSON.parse(localStorage.getItem('robotdoc_cs')) || ["Kevin S"];

  document.addEventListener("DOMContentLoaded", () => {
    updateCsUI();
    updateStats([]);
  });

  /* =====================
     CS MANAGEMENT
  ===================== */
  function updateCsUI() {
    const select = document.getElementById("csSelect");
    const prev = select.value;
    select.innerHTML = '<option value="">— CS —</option>';

    csNames.forEach(n => {
      const opt = document.createElement("option");
      opt.value = n;
      opt.textContent = n;
      select.appendChild(opt);
    });

    if (csNames.includes(prev)) select.value = prev;

    const list = document.getElementById("csList");
    list.innerHTML = "";

    csNames.forEach(n => {
      const div = document.createElement("div");
      div.className = "cs-item" + (select.value === n ? " selected" : "");
      div.innerHTML = `
        <span>${n}</span>
        <button class="cs-remove" onclick="removeCs('${n}')" title="Hapus">×</button>
      `;
      div.addEventListener("click", (e) => {
        if (e.target.tagName === "BUTTON") return;
        document.getElementById("csSelect").value = n;
        updateCsHighlight();
        processData();
      });
      list.appendChild(div);
    });

    localStorage.setItem('robotdoc_cs', JSON.stringify(csNames));
  }

  function updateCsHighlight() {
    const val = document.getElementById("csSelect").value;
    document.querySelectorAll(".cs-item").forEach((el, i) => {
      el.classList.toggle("selected", csNames[i] === val);
    });
  }

  function addCs() {
    const inp = document.getElementById("newCsInput");
    const name = inp.value.trim();
    if (name && !csNames.includes(name)) {
      csNames.push(name);
      updateCsUI();
      inp.value = "";
      showToast("CS ditambahkan");
    }
  }

  function removeCs(name) {
    if (!confirm(`Hapus CS "${name}"?`)) return;
    csNames = csNames.filter(n => n !== name);
    updateCsUI();
  }

  /* =====================
     PROCESS
  ===================== */
  function clearData() {
    document.getElementById("rawData").value = "";
    processData();
  }

  function processData() {
    const raw = document.getElementById("rawData").value.trim();
    const cs = document.getElementById("csSelect").value;
    updateCsHighlight();

    if (!raw || !cs) {
      allResults = [];
      renderTable([]);
      updateStats([]);
      return;
    }

    const results = [];
    const lines = raw.split('\n').map(l => l.trim()).filter(l => l !== "");

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i].toLowerCase();
      if (!line.includes("withdraw") && !line.includes("deposit")) continue;

      let res = {
        cs,
        id: "N/A",
        type: line.includes("withdraw") ? "Withdraw" : "Deposit",
        nominal: "0",
        rawNominal: 0,
        nama: "N/A",
        channel: ""
      };

      if (i > 0) {
        const idParts = lines[i - 1].split(/\s+/);
        res.id = idParts[idParts.length - 1];
      }

      const candidates = line.match(/\d[\d.,]*/g);
      if (candidates) {
        const validNominals = candidates
          .map(n => {
            let cleaned = n.includes('.') ? n.split('.')[0] : n;
            cleaned = cleaned.replace(/,/g, '');
            return parseInt(cleaned, 10);
          })
          .filter(n => !isNaN(n) && n >= 10000 && n < 100000000 && ![2024, 2025, 2026].includes(n));

        if (validNominals.length > 0) {
          let nominalValue = validNominals[0];

          for (let j = i + 1; j < i + 6 && j < lines.length; j++) {
            if (lines[j].includes(",")) {
              const upper = lines[j].toUpperCase();
              if (upper.includes("GOPAY")) res.channel = "GOPAY";
              else if (upper.includes("LINKAJA")) res.channel = "LINKAJA";

              const bankParts = lines[j].split(',');
              if (bankParts.length >= 3) {
                res.nama = bankParts[2].split(/\t/)[0]
                  .split("From :")[0].trim();
              }
              break;
            }
          }

          if (res.type === "Withdraw" && (res.channel === "GOPAY" || res.channel === "LINKAJA")) {
            nominalValue += 1000;
          }

          res.rawNominal = res.type === "Withdraw" ? -nominalValue : nominalValue;
          res.nominal = (res.type === "Withdraw" ? "-" : "") + nominalValue.toLocaleString('id-ID');
        }
      }

      if (res.id !== "N/A" && res.nominal !== "0") {
        results.push(res);
      }
    }

    allResults = results;
    const filtered = filterByTab();
    renderTable(filtered);
    updateStats(allResults);
  }

  /* =====================
     STATS
  ===================== */
  function updateStats(data) {
    const totalDep = data.filter(d => d.type === "Deposit").reduce((s, d) => s + d.rawNominal, 0);
    const totalWd = data.filter(d => d.type === "Withdraw").reduce((s, d) => s + Math.abs(d.rawNominal), 0);
    const net = totalDep - totalWd;

    const fmt = (n) => n === 0 ? "—" : n.toLocaleString('id-ID');

    document.getElementById("statTotal").textContent = data.length || "—";
    document.getElementById("statDeposit").textContent = totalDep > 0 ? fmt(totalDep) : "—";
    document.getElementById("statWithdraw").textContent = totalWd > 0 ? fmt(totalWd) : "—";

    const netEl = document.getElementById("statNet");
    netEl.textContent = data.length > 0 ? (net >= 0 ? "+" : "") + fmt(Math.abs(net)) : "—";
    netEl.className = "summary-value " + (net >= 0 ? "val-net-pos" : "val-net-neg");
    if (data.length === 0) netEl.className = "summary-value val-neutral";
  }

  /* =====================
     TABLE
  ===================== */
  function renderTable(data) {
    const tbody = document.getElementById("successTableBody");
    document.getElementById("successCount").textContent = data.length;

    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="5">
        <div class="empty-state">
          <div class="icon">◈</div>
          <div>${allResults.length > 0 ? "Tidak ada data untuk filter ini." : "Masukkan data transaksi."}</div>
        </div>
      </td></tr>`;
      btnCopyNom.disabled = true;
      btnCopyAll.disabled = true;
      window.currentData = [];
      return;
    }

    tbody.innerHTML = data.map(d => {
      const isWd = d.type === "Withdraw";
      return `<tr>
        <td class="mono" style="font-size:11px;">${d.cs}</td>
        <td style="font-weight:600;text-transform:uppercase;font-size:11px;">${d.nama}</td>
        <td class="mono" style="color:var(--accent);font-size:11px;">${d.id}</td>
        <td><span class="type-badge ${isWd ? 'type-wd' : 'type-dep'}">${d.type}</span></td>
        <td class="num ${isWd ? 'val-wd' : 'val-dep'}">${d.nominal}</td>
      </tr>`;
    }).join('');

    btnCopyNom.disabled = false;
    btnCopyAll.disabled = false;
    window.currentData = data;
  }

  /* =====================
     COPY
  ===================== */
  function copyAllNominal() {
    if (!window.currentData?.length) return;
    navigator.clipboard.writeText(
      window.currentData.map(d => d.nominal).join('\n')
    ).then(() => showToast("Nominal disalin"));
  }

  function copyAllData() {
    if (!window.currentData?.length) return;
    navigator.clipboard.writeText(
      window.currentData.map(d => `${d.cs}\t${d.nama}\t${d.id}\t${d.type}\t${d.nominal}`).join('\n')
    ).then(() => showToast("Data disalin"));
  }

  /* =====================
     TABS
  ===================== */
  function setTab(tab) {
    activeTab = tab;
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    renderTable(filterByTab());
  }

  function filterByTab() {
    if (activeTab === 'deposit') return allResults.filter(d => d.type === "Deposit");
    if (activeTab === 'withdraw') return allResults.filter(d => d.type === "Withdraw");
    return allResults;
  }

  /* =====================
     TOAST
  ===================== */
  function showToast(msg) {
    const t = document.getElementById("toast");
    t.textContent = msg;
    t.classList.add("show");
    setTimeout(() => t.classList.remove("show"), 2000);
  }
</script>

</body>
</html>
